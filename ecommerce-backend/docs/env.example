# This file is entirely OPTIONAL. docker-compose.yml already has a working
# default for every one of these - `docker compose up` boots fine with no
# .env at all. Only uncomment + set the ones you actually want to override.
#
# Most likely one to change: JWT_SECRET, if this is going anywhere beyond a
# quick local demo.
#   openssl rand -hex 64

# ---- database ----
# DB_USERNAME=app_user
# DB_PASSWORD=change_me_super_secret
# DB_DATABASE=ecommerce

# ---- redis ----
# REDIS_PASSWORD=

# ---- auth ----
# JWT_SECRET=
# JWT_ABSOLUTE_EXPIRES_IN=12h
# SESSION_INACTIVITY_TIMEOUT_SECONDS=3600

# ---- login anti-abuse ----
# LOGIN_RATE_LIMIT_IP_MAX=10
# LOGIN_RATE_LIMIT_IP_WINDOW_SECONDS=60
# LOGIN_LOCKOUT_MAX_ATTEMPTS=5
# LOGIN_LOCKOUT_WINDOW_SECONDS=900
# LOGIN_LOCKOUT_DURATION_SECONDS=900

# ---- seed data ----
# SEED_DEMO_USER_PASSWORD=Password@2026
# SEED_PRODUCT_COUNT=5000

# ---- cors / frontend ----
# Origin the frontend runs on (browser -> backend CORS check).
# CORS_ORIGINS=http://localhost:3001
# Backend URL the BROWSER can reach - baked into the frontend's JS bundle
# at build time, so changing this needs `docker compose up --build`.
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3002/ecom/v1
