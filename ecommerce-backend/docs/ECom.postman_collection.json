          "name": "Login - username",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Parse the response body",
                  "const response = pm.response.json();",
                  "",
                  "// Check if login was successful",
                  "if (response?.accessToken) {",
                  "    ",
                  "    // Set the access token as a collection variable",
                  "    pm.collectionVariables.set(\"access_token\", `Bearer ${response.accessToken}`);",
                  "    ",
                  "    console.log(\"✅ Access token saved to collection variables\");",
                  "} else {",
                  "    console.log(\"❌ Login failed, token not saved\");",
                  "}"
                ],
